{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Create your blog content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "post_category": {
      "type": "enumeration",
      "enum": [
        "Student Spotlight",
        "Community Development",
        "Opportunities"
      ]
    },
    "post_title": {
      "type": "string"
    },
    "post_author": {
      "type": "string"
    },
    "postDate": {
      "type": "datetime"
    },
    "post_content": {
      "type": "richtext"
    }
  }
}
